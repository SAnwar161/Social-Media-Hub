{
  "expo": {
    "name": "Element",
    "slug": "Element",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/ICON/social_media_hub_app_icon.jpg",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/ICON/social_media_hub_app_icon.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sadat.element"
    },
    "android": {
      "package": "com.sadat.element",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "element"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        },
        {
          "action": "SEND",
          "data": [
            {
              "mimeType": "text/plain"
            }
          ],
          "category": [
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/ICON/social_media_hub_app_icon.jpg"
    },
    "extra": {
      "eas": {
        "projectId": "9b5591cf-9031-403c-b90c-739de48a8eea"
      }
    },
    "owner": "sadat161"
  }
}
