{
  "name": "element",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest --watchAll=false"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "@testing-library/jest-native/extend-expect",
      "<rootDir>/jest.setup.js"
    ],
    "moduleNameMapper": {
      "^react-native-webview$": "<rootDir>/src/__mocks__/react-native-webview.js",
      "^react-native-safe-area-context$": "<rootDir>/src/__mocks__/react-native-safe-area-context.js",
      "^@expo/vector-icons$": "<rootDir>/src/__mocks__/@expo/vector-icons.js",
      "^@react-navigation/bottom-tabs$": "<rootDir>/src/__mocks__/@react-navigation/bottom-tabs.js",
      "^@react-navigation/native$": "<rootDir>/src/__mocks__/@react-navigation/native.js",
      "^expo-modules-core$": "<rootDir>/src/__mocks__/expo-modules-core.js",
      "^expo/.*": "<rootDir>/src/__mocks__/expo-modules-core.js"
    }
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-navigation/bottom-tabs": "^6.5.20",
    "@react-navigation/native": "^6.1.17",
    "expo": "~54.0.0",
    "expo-clipboard": "~8.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "~8.0.11",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-webview": "13.15.0"
  },
  "private": true,
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.6.0",
    "babel-preset-expo": "~12.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0"
  }
}
